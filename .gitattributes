# Kindle device scripts MUST keep Unix (LF) line endings.
# A CRLF shebang (e.g. "#!/bin/sh\r") makes the Kindle's sh look for an
# interpreter literally named "/bin/sh<CR>" and fail with "not found".
# Forcing LF here prevents git's autocrlf from re-breaking these on a
# Windows checkout.
*.sh   text eol=lf
*.py   text eol=lf
*.conf text eol=lf
*.svg  text eol=lf
*.cfg  text eol=lf

# Extensionless shell wrappers (no .sh suffix) that MUST stay LF.
extensions/weather-stand/bin/rsvg-convert text eol=lf

# ...but the real ELF binary of the same name in the lib dir is NOT text.
extensions/weather-stand/bin/rsvg-convert-lib/rsvg-convert binary
**/pngcrush binary
*.so   binary
*.so.* binary

# Binary assets - never line-ending convert or diff as text.
*.bin    binary
*.tar.gz binary
*.tar.xz binary
*.xz     binary
*.gz     binary
*.zip    binary
*.azw2   binary
*.ttf    binary
*.jpg    binary
*.jpeg   binary
*.png    binary
*.pyc    binary
